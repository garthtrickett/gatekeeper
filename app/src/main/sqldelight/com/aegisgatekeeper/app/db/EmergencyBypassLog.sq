CREATE TABLE IF NOT EXISTS EmergencyBypassLog (
    id TEXT NOT NULL PRIMARY KEY,
    packageName TEXT NOT NULL,
    reason TEXT NOT NULL,
    timestamp INTEGER NOT NULL
);

insert:
INSERT INTO EmergencyBypassLog(id, packageName, reason, timestamp)
VALUES (:id, :packageName, :reason, :timestamp);

selectAll:
SELECT * FROM EmergencyBypassLog ORDER BY timestamp DESC;
